# Copy to .env (git-ignored) and fill in. ALL are optional:
# without them the pipeline runs on seed data with deterministic enrichment.

# Claude reasoning layer (transfer-dimension scoring + narrative). Optional.
ANTHROPIC_API_KEY=

# Live Reddit collection (community_forum connector). Optional — seed is used otherwise.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=alpine-signal-radar/0.1
